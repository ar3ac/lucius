[Unit]
Description=Lucius (PiCmdHub) Web App
After=network.target

[Service]
# REPLACE: The username that will run the tool (e.g. pi, ubuntu, ar3ac)
User=pi
# REPLACE: The absolute path where the project folder is located
WorkingDirectory=/home/pi/lucius
# The uvicorn executable inside the virtualenv (.venv)
ExecStart=/home/pi/lucius/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
